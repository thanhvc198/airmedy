<?xml version="1.0" encoding="utf-8"?>
<MsixPackagingToolTemplate
    xmlns="http://schemas.microsoft.com/msix/packaging/msixpackagingtool/template/2022">
    <Settings
        AllowTelemetry="false"
        ApplyACLsToPackageFiles="true"
        GenerateCommandLineFile="true"
        AllowPromptForPassword="false">
    </Settings>
    <Installer
        Path="airmedy"
        Arguments=""
        InstallLocation="C:\Program Files\misa198\Airmedy">
    </Installer>
    <PackageInformation
        PackageName="Airmedy"
        PackageDisplayName="Airmedy"
        PublisherName="CN=misa198"
        PublisherDisplayName="misa198"
        Version="1.0.0.0"
        PackageDescription="A airmedy application">
        <Capabilities>
            <Capability Name="runFullTrust" />
            
        </Capabilities>
        <Applications>
            <Application
                Id="me.misa198.airmedy"
                Description="A airmedy application"
                DisplayName="Airmedy"
                ExecutableName="airmedy"
                EntryPoint="Windows.FullTrustApplication">
                
            </Application>
        </Applications>
        <Resources>
            <Resource Language="en-us" />
        </Resources>
        <Dependencies>
            <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.19041.0" />
        </Dependencies>
        <Properties>
            <Framework>false</Framework>
            <DisplayName>Airmedy</DisplayName>
            <PublisherDisplayName>misa198</PublisherDisplayName>
            <Description>A airmedy application</Description>
            <Logo>Assets\AppIcon.png</Logo>
        </Properties>
    </PackageInformation>
    <SaveLocation PackagePath="airmedy.msix" />
    <PackageIntegrity>
        <CertificatePath></CertificatePath>
    </PackageIntegrity>
</MsixPackagingToolTemplate>
